{
  "name": "Cognitive Execution System (CES)",
  "version": "0.1.0",
  "private": true,
  "description": "Cognitive Execution System (CES) - Cognitive execution workspace",
  "license": "AGPL-3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test:core": "tsx tests/core.test.ts",
    "test:e2e": "tsx tests/multimodal-e2e.test.ts && tsx tests/webspec-e2e.test.ts",
    "test": "npm run test:core && npm run test:e2e",
    "ci:quality": "npm run lint && npm run test && npm run build && npm audit --omit=dev --audit-level=high",
    "release:gate": "npm run typecheck && npm run lint && npm run test && npm run build && npm run preflight && npm run perf:lighthouse && npm audit --omit=dev --audit-level=high",
    "preflight": "node scripts/preflight-check.mjs",
    "preflight:live": "node scripts/preflight-live-check.mjs",
    "preflight:full": "npm run preflight && npm run preflight:live",
    "perf:lighthouse": "npx --yes @lhci/cli autorun --config=lighthouserc.json",
    "api": "tsx api/server.ts",
    "api:dev": "tsx watch api/server.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^11.0.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.344.0",
    "next": "^15.5.15",
    "openai": "^4.28.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^16.1.1",
    "stripe": "^22.0.1",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-syntax-highlighter": "^15.5.11",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0"
  }
}
