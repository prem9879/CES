# Core site settings
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_STATIC_EXPORT=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:7860

# Optional analytics providers (consent-gated)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Supabase auth (required for /auth flows)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CES API / runtime auth
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
GOOGLE_OAUTH_CLIENT_ID=

# Optional server-side provider key for shared CES access.
# Do NOT expose this key in frontend bundles.
OPENROUTER_API_KEY=

# Billing links (Stripe hosted checkout/payment links)
NEXT_PUBLIC_STRIPE_LINK_PRO=
NEXT_PUBLIC_STRIPE_LINK_ENTERPRISE=

# Stripe server billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_FREE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:3000/billing?status=success
STRIPE_CANCEL_URL=http://localhost:3000/billing?status=cancelled
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/billing/
STRIPE_WEBHOOK_SECRET=

# Preflight live checker options
PREFLIGHT_TIMEOUT_MS=8000
PREFLIGHT_STRICT_LIVE=false
# Comma-separated tokens to detect in uniqueness scan
BRAND_BLOCKLIST=legacy-brand,legacy-upstream
